{
  "name": "@daofun/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./launch-form": {
      "types": "./src/launch-form.ts",
      "default": "./src/launch-form.ts"
    },
    "./matrix": {
      "types": "./src/matrix.ts",
      "default": "./src/matrix.ts"
    },
    "./pda": {
      "types": "./src/pda.ts",
      "default": "./src/pda.ts"
    },
    "./constants": {
      "types": "./src/constants.ts",
      "default": "./src/constants.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./vsr": {
      "types": "./src/vsr.ts",
      "default": "./src/vsr.ts"
    },
    "./treasury": {
      "types": "./src/treasury.ts",
      "default": "./src/treasury.ts"
    },
    "./governance": {
      "types": "./src/governance.ts",
      "default": "./src/governance.ts"
    },
    "./rails/pumpfun": {
      "types": "./src/rails/pumpfun.ts",
      "default": "./src/rails/pumpfun.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.30.1",
    "@pump-fun/pump-sdk": "1.36.0",
    "@pump-fun/pump-swap-sdk": "1.17.0",
    "@solana/spl-governance": "0.3.28",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "@sqds/multisig": "2.1.4",
    "bn.js": "5.2.3",
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.6",
    "fast-check": "4.5.3"
  }
}
