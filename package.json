{
  "name": "pumpfun-dao-launchpad",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run && pnpm -r run test",
    "test:unit": "vitest run --exclude 'tests/**/*.integration.test.ts' && pnpm -r run test:unit",
    "test:integration": "vitest run tests --testTimeout=300000",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "init-wallets": "tsx scripts/init-wallets.ts",
    "gate:0a": "tsx scripts/devnet-validate-creator.ts"
  },
  "devDependencies": {
    "@pump-fun/pump-sdk": "1.36.0",
    "@solana/spl-governance": "0.3.28",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "@sqds/multisig": "2.1.4",
    "@types/bn.js": "^5.1.6",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bn.js": "5.2.2",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "solana-bankrun": "0.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
