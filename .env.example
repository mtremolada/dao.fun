# All defaults work with zero third-party signups (spec Section 3).
CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com        # public default; Helius optional
HELIUS_API_KEY=                              # optional; features degrade gracefully
PROTOCOL_LAUNCH_FEE_LAMPORTS=50000000        # 0.05 SOL default, operator-tunable
PROTOCOL_SHARE_BPS=1000                      # only used if GATE 0c passes
ARTIFACT_STORE=sqlite:.data/artifacts.db     # sim/decode artifacts (spec 12.3)

# --- Front end (static, server-less; D-033) ---------------------------------
# NEXT_PUBLIC_* are inlined into the static bundle at build time. The app
# reads the chain and signs in the browser; there is no backend in the
# deployment. Users can override the RPC at runtime (stored in localStorage).
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com  # default RPC endpoint
NEXT_PUBLIC_PROTOCOL_TREASURY=               # launch-fee recipient (defaults to the launcher if empty)
NEXT_PUBLIC_LAUNCH_FEE=0                      # launch fee in lamports
NEXT_PUBLIC_BASE_PATH=                        # /subpath for path/subdir hosting; empty for IPFS subdomain gateways or a domain root
