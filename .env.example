# All defaults work with zero third-party signups (spec Section 3).
CLUSTER=devnet
RPC_URL=https://api.devnet.solana.com        # public default; Helius optional
HELIUS_API_KEY=                              # optional; features degrade gracefully
PROTOCOL_LAUNCH_FEE_LAMPORTS=50000000        # 0.05 SOL default, operator-tunable
PROTOCOL_SHARE_BPS=1000                      # only used if GATE 0c passes (gated in MVP)
ARTIFACT_STORE=sqlite:.data/artifacts.db     # sim/decode artifacts (spec 12.3)

# --- Production backend (scripts/serve-mainnet.ts) — required to run live ---
# PROTOCOL_TREASURY=<base58 pubkey you control>  # receives launch fees (operator-supplied)
# DEPLOYER_KEYPAIR=/secure/path/deployer.json    # launcher/gas hot key (Solana CLI keypair file)
# SERVER_KEYPAIR_SEED=<long random secret>       # derives per-launch keypairs; keep secret + backed up
# API_AUTH_TOKEN=<long random secret>            # Bearer gating POST /launches and /snapshots
# LAUNCH_STORE=sqlite:.data/launches.db          # durable, resumable launch state
# API_PORT=4404
